<Window x:Class="Speakly.FloatingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Speakly Overlay"
        Width="280"
        Height="64"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        MinWidth="280"
        MinHeight="64"
        MaxWidth="1800"
        MaxHeight="600"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="OverlayContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{DynamicResource OverlaySkin.MenuBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OverlaySkin.MenuBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource OverlaySkin.MenuForegroundBrush}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="6"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource OverlaySkin.MenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource OverlaySkin.MenuBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OverlaySkin.MenuBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <Grid TextElement.Foreground="{TemplateBinding Foreground}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="CheckBoxBorder"
                                            Width="16"
                                            Height="16"
                                            CornerRadius="4"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource OverlaySkin.MenuBorderBrush}"
                                            Background="Transparent"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />

                                    <TextBlock x:Name="CheckGlyph"
                                               Text="✓"
                                               Width="16"
                                               Height="16"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               Visibility="Collapsed" />

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="10,0,0,0"
                                                      VerticalAlignment="Center"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True" />

                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="2"
                                          Width="6"
                                          Height="10"
                                          Margin="4,0,0,0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 5 L 0 10"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.6"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PopupAnimation="Fade">
                                <Border Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
                                        BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="6"
                                        Margin="8,0,0,0"
                                        SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource OverlaySkin.MenuItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
                            </Trigger>
                            <Trigger Property="IsCheckable" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayMenuSeparatorStyle" TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="Background" Value="{DynamicResource OverlaySkin.MenuBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Background="{TemplateBinding Background}"
                                Margin="{TemplateBinding Margin}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="ToastBorder"
                Grid.Row="0"
                HorizontalAlignment="Left"
                Margin="12,0,0,6"
                Padding="12,5"
                CornerRadius="10"
                BorderThickness="1"
                Background="{DynamicResource OverlaySkin.ToastBrush}"
                BorderBrush="{DynamicResource OverlaySkin.ToastBorderBrush}"
                Visibility="Collapsed">
            <TextBlock x:Name="ToastText"
                       Text="Transcription complete"
                       Foreground="{DynamicResource OverlaySkin.ToastForegroundBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="SemiBold" />
        </Border>

        <Border x:Name="Container"
                Grid.Row="1"
                CornerRadius="32"
                BorderThickness="1"
                BorderBrush="{DynamicResource OverlaySkin.PillowIdleBorderBrush}"
                Padding="16,10"
                Background="{DynamicResource OverlaySkin.PillowIdleBrush}"
                ClipToBounds="True"
                MouseDown="Container_MouseDown">
            <Grid x:Name="ContainerContent" ClipToBounds="True">
                <Canvas x:Name="WaveCanvas"
                        Opacity="0.35"
                        IsHitTestVisible="False"
                        Margin="58,0,0,0" />

                <Grid x:Name="MainLayoutGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="MicColumn" Width="Auto" />
                        <ColumnDefinition x:Name="StatusColumn" Width="*" />
                        <ColumnDefinition x:Name="BadgesColumn" Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="MicCluster"
                          Grid.Column="0"
                          Width="44"
                          Height="44"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"
                          ClipToBounds="False">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="MicClusterScaleTransform" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                        <Ellipse x:Name="MicRingTrack"
                                 Width="42"
                                 Height="42"
                                 StrokeThickness="1.2"
                                 Stroke="{DynamicResource OverlaySkin.PillowIdleBorderBrush}"
                                 Opacity="0.75"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                        <Ellipse x:Name="MicRingActive"
                                 Width="42"
                                 Height="42"
                                 StrokeThickness="2.2"
                                 StrokeDashArray="3 3"
                                 StrokeStartLineCap="Round"
                                 StrokeEndLineCap="Round"
                                 Stroke="{DynamicResource OverlaySkin.IconIdleBrush}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="MicRingRotate" Angle="0" CenterX="21" CenterY="21" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Border x:Name="MicBg"
                                Width="32"
                                Height="32"
                                CornerRadius="16"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource OverlaySkin.PillowIdleBorderBrush}"
                                Background="{DynamicResource OverlaySkin.PillowIdleBrush}"
                                SnapsToDevicePixels="True"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ui:SymbolIcon x:Name="MicIcon"
                                           Symbol="Mic24"
                                           FontSize="16"
                                           Foreground="{DynamicResource OverlaySkin.IconIdleBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <StackPanel x:Name="StatusStack"
                                Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Text="Ready"
                                   FontSize="13"
                                   Margin="0,-7,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OverlaySkin.StatusForegroundBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="SubStatusText"
                                   Text="Hold hotkey to speak"
                                   FontSize="11"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource OverlaySkin.SubtleTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel x:Name="BadgeStack"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="ContextBadge"
                                Background="{DynamicResource OverlaySkin.LanguageBadgeBrush}"
                                BorderBrush="{DynamicResource OverlaySkin.LanguageBadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4"
                                Margin="0,0,6,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="ContextText"
                                       Text="CTX"
                                       Foreground="{DynamicResource OverlaySkin.LanguageBadgeForegroundBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>

                        <Border x:Name="ModeBadge"
                                Background="{DynamicResource OverlaySkin.LanguageBadgeBrush}"
                                BorderBrush="{DynamicResource OverlaySkin.LanguageBadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4"
                                Margin="0,0,6,0">
                            <TextBlock x:Name="ModeText"
                                       Text="Plain"
                                       Foreground="{DynamicResource OverlaySkin.LanguageBadgeForegroundBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>

                        <Border x:Name="TimerBadge"
                                Background="{DynamicResource OverlaySkin.TimerBackgroundBrush}"
                                BorderBrush="{DynamicResource OverlaySkin.PillowIdleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4"
                                Margin="0,0,6,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TimerText"
                                       Text="0:00"
                                       Foreground="{DynamicResource OverlaySkin.TimerForegroundBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Border>

                        <Border x:Name="LanguageBadge"
                                Background="{DynamicResource OverlaySkin.LanguageBadgeBrush}"
                                BorderBrush="{DynamicResource OverlaySkin.LanguageBadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4"
                                Visibility="Collapsed">
                            <TextBlock x:Name="LanguageText"
                                       Text="EN"
                                       Foreground="{DynamicResource OverlaySkin.LanguageBadgeForegroundBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid.ContextMenu>
                    <ContextMenu x:Name="OverlayContextMenu"
                                 Opened="OverlayContextMenu_Opened"
                                 Style="{StaticResource OverlayContextMenuStyle}"
                                 Background="{DynamicResource OverlaySkin.MenuBrush}"
                                 BorderBrush="{DynamicResource OverlaySkin.MenuBorderBrush}"
                                 BorderThickness="1"
                                 Foreground="{DynamicResource OverlaySkin.MenuForegroundBrush}">
                        <MenuItem x:Name="StartStopMenuItem"
                                  Style="{StaticResource OverlayMenuItemStyle}"
                                  Header="Start Recording"
                                  Click="StartStopMenuItem_Click" />
                        <Separator Style="{StaticResource OverlayMenuSeparatorStyle}" />
                        <MenuItem Style="{StaticResource OverlayMenuItemStyle}"
                                  Header="Next Mode"
                                  Click="NextModeMenuItem_Click" />
                        <MenuItem x:Name="ModesMenuItem"
                                  Style="{StaticResource OverlayMenuItemStyle}"
                                  Header="Modes" />
                        <MenuItem Style="{StaticResource OverlayMenuItemStyle}"
                                  Header="Toggle Refinement"
                                  Click="ToggleRefinementMenuItem_Click" />
                        <MenuItem Style="{StaticResource OverlayMenuItemStyle}"
                                  Header="Next Profile"
                                  Click="NextProfileMenuItem_Click" />
                        <MenuItem Style="{StaticResource OverlayMenuItemStyle}"
                                  Header="Settings"
                                  Click="SettingsMenuItem_Click" />
                        <MenuItem Style="{StaticResource OverlayMenuItemStyle}"
                                  Header="Hide for now"
                                  Click="HideMenuItem_Click" />
                    </ContextMenu>
                </Grid.ContextMenu>
            </Grid>
        </Border>
    </Grid>
</Window>
