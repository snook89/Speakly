<Window x:Class="Speakly.FloatingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speakly Overlay"
        Width="260" Height="90"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MinWidth="180" MinHeight="70">

    <!-- Draggable container -->
    <Border x:Name="Container"
            Background="#D9121212"
            CornerRadius="18"
            Padding="14,10"
            MouseDown="Container_MouseDown"
            Cursor="SizeAll">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Row: indicator dot + status text + timer -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse x:Name="StatusIndicator"
                         Grid.Column="0"
                         Width="9" Height="9"
                         Fill="#00D2FF"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>

                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="READY"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="TimerText"
                           Grid.Column="2"
                           Text=""
                           Foreground="#AAAAAA"
                           FontSize="11"
                           FontFamily="Segoe UI Semibold"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>

            <!-- Bottom Row: Waveform canvas -->
            <Canvas x:Name="WaveCanvas"
                    Grid.Row="1"
                    Height="28"
                    Margin="0,6,0,0"
                    ClipToBounds="True"/>
        </Grid>
    </Border>
</Window>
