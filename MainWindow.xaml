<Window x:Class="Speakly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Speakly"
        xmlns:vm="clr-namespace:Speakly.ViewModels"
        mc:Ignorable="d"
        Title="Speakly - Settings" Height="640" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBgBrush}"
        Foreground="{DynamicResource AppFgBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Tab style -->
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Margin="0,0,6,0" Padding="14,9" Background="Transparent" CornerRadius="8">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AppControlSelectedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppFgBrush}"/>
        </Style>

        <!-- PasswordBox style -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource AppControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- ComboBox style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource AppControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- ComboBoxItem style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}"/>
        </Style>

        <!-- Reveal button -->
        <Style x:Key="RevealButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppControlBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="SPEAKLY" FontSize="30" FontWeight="Black" Foreground="{DynamicResource AppAccentBrush}"/>
            <TextBlock Text="AI-Powered Push-to-Talk Transcription" FontSize="13" Foreground="{DynamicResource AppTextMutedBrush}"/>
        </StackPanel>

        <!-- Main Tabs -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- General Tab -->
            <TabItem Header="General" Style="{StaticResource ModernTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Theme" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedValue="{Binding Theme}" SelectedValuePath="Content" Margin="0,0,0,18">
                            <ComboBoxItem Content="Dark"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="Matrix"/>
                            <ComboBoxItem Content="Ocean"/>
                        </ComboBox>

                        <CheckBox Content="Minimize to Tray on Close" IsChecked="{Binding MinimizeToTray}"
                                  Foreground="{DynamicResource AppFgBrush}" Margin="0,0,0,12"/>
                        <CheckBox Content="Enable Debug Logs" IsChecked="{Binding EnableDebugLogs}"
                                  Foreground="{DynamicResource AppFgBrush}" Margin="0,0,0,18"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Hotkeys Tab -->
            <TabItem Header="Hotkeys" Style="{StaticResource ModernTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">

                        <TextBlock Text="Push-to-Talk key (hold to record, release to transcribe)"
                                   Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PttHotkeyBox" Text="{Binding PttHotkey}" Grid.Column="0" IsReadOnly="True" Cursor="Hand" />
                            <Button x:Name="SetPttBtn" Grid.Column="1" Content="Set Key" Margin="6,0,0,0" Padding="10,0" Click="SetPtt_Click" Background="{DynamicResource AppControlBorderBrush}" Foreground="{DynamicResource AppFgBrush}" BorderThickness="0" Cursor="Hand"/>
                        </Grid>
                        <TextBlock Text="e.g. Space · LeftCtrl · LeftAlt · F1 … F12"
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,20"/>

                        <TextBlock Text="Toggle-Record key (one press starts, another press stops)"
                                   Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RecordHotkeyBox" Text="{Binding RecordHotkey}" Grid.Column="0" IsReadOnly="True" Cursor="Hand" />
                            <Button x:Name="SetRecBtn" Grid.Column="1" Content="Set Key" Margin="6,0,0,0" Padding="10,0" Click="SetRec_Click" Background="{DynamicResource AppControlBorderBrush}" Foreground="{DynamicResource AppFgBrush}" BorderThickness="0" Cursor="Hand"/>
                        </Grid>
                        <TextBlock Text="e.g. F9 · Insert · Scroll Lock — must differ from PTT key"
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Audio Tab -->
            <TabItem Header="Audio" Style="{StaticResource ModernTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Microphone Input Device" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableAudioDevices}" SelectedItem="{Binding AudioDevice}" Margin="0,0,0,18"/>

                        <TextBlock Text="Sample Rate (Hz)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SampleRate}" Margin="0,0,0,5"/>
                        <TextBlock Text="Hint: 16000 is recommended for most STT models (Nova-3, Whisper)."
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,18"/>

                        <TextBlock Text="Chunk Size (Bytes)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding ChunkSize}" Margin="0,0,0,5"/>
                        <TextBlock Text="Hint: 4096 is standard. Smaller values decrease latency but increase CPU usage."
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,18"/>

                        <TextBlock Text="Channels" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Channels}" Margin="0,0,0,5"/>
                        <TextBlock Text="Hint: 1 (Mono) is best. Most AI models only support mono input."
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,18"/>

                        <CheckBox Content="Save Debug Records" IsChecked="{Binding SaveDebugRecords}" Margin="0,10,0,5"/>
                        <TextBlock Text="Saves timestamped .wav files to 'Records' folder for troubleshooting."
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,18"/>

                        <TextBlock Text="Settings take effect on the next transcription session."
                                   FontSize="11" Foreground="{DynamicResource AppAccentBrush}" Margin="0,10,0,20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Transcription Tab -->
            <TabItem Header="Transcription" Style="{StaticResource ModernTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Speech-to-Text Service" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedValue="{Binding SttModel}" SelectedValuePath="Content" Margin="0,0,0,18">
                            <ComboBoxItem Content="Deepgram"/>
                            <ComboBoxItem Content="OpenAI"/>
                        </ComboBox>

                        <TextBlock Text="Language (ISO Code)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Language}" Margin="0,0,0,5"/>
                        <TextBlock Text="e.g. 'en', 'uk', 'es'. For Deepgram streaming, 'auto' uses multilingual mode ('multi')."
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,18"/>

                        <TextBlock Text="Target Model" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableSttModels}" 
                                  Text="{Binding SelectedSttModelString}" 
                                  IsEditable="True" 
                                  Margin="0,0,0,8"/>

                        <Button Content="REFRESH MODELS"
                                Command="{Binding RefreshModelsCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,6"
                                Padding="16,6"
                                Background="{DynamicResource AppControlBorderBrush}"
                                Foreground="{DynamicResource AppFgBrush}"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"/>
                        <TextBlock Text="{Binding ModelRefreshStatus}"
                                   FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,18"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Refinement Tab -->
            <TabItem Header="Refinement" Style="{StaticResource ModernTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Refinement Service" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedValue="{Binding RefinementModel}" SelectedValuePath="Content" Margin="0,0,0,18">
                            <ComboBoxItem Content="OpenAI"/>
                            <ComboBoxItem Content="OpenRouter"/>
                            <ComboBoxItem Content="Cerebras"/>
                        </ComboBox>

                        <TextBlock Text="Target Model" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableRefinementModels}" 
                                  Text="{Binding SelectedRefinementModelString}" 
                                  IsEditable="True" 
                              Margin="0,0,0,12"/>

                        <TextBlock Text="Prompt Presets" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Preset 1 (General)"
                                Command="{Binding ApplyRefinementPromptPresetCommand}"
                                CommandParameter="GENERAL"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Background="{DynamicResource AppControlBorderBrush}"
                                Foreground="{DynamicResource AppFgBrush}"
                                BorderThickness="0"
                                Cursor="Hand"/>
                            <Button Content="Preset 2 (Ukrainian)"
                                Command="{Binding ApplyRefinementPromptPresetCommand}"
                                CommandParameter="UK"
                                Padding="12,6"
                                Background="{DynamicResource AppControlBorderBrush}"
                                Foreground="{DynamicResource AppFgBrush}"
                                BorderThickness="0"
                                Cursor="Hand"/>
                            <Button Content="Reset Prompt"
                                Command="{Binding ResetRefinementPromptCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0"
                                Background="{DynamicResource AppControlBorderBrush}"
                                Foreground="{DynamicResource AppFgBrush}"
                                BorderThickness="0"
                                Cursor="Hand"/>
                        </StackPanel>

                        <TextBlock Text="Custom System Prompt" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding RefinementPrompt}" AcceptsReturn="True" Height="140"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,18"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- API Keys Tab -->
            <TabItem Header="API Keys" Style="{StaticResource ModernTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">

                        <!-- Deepgram -->
                        <TextBlock Text="Deepgram API Key" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="DeepgramPwdBox" Grid.Column="0"/>
                            <TextBox x:Name="DeepgramTxtBox" Grid.Column="0" Visibility="Collapsed"
                                     Text="{Binding DeepgramApiKey}"/>
                            <Button Grid.Column="1" x:Name="DeepgramReveal" Content="👁 Show"
                                    Style="{StaticResource RevealButton}" Margin="6,0,0,0"
                                    Click="RevealApiKey_Click" Tag="Deepgram"/>
                        </Grid>

                        <!-- OpenAI -->
                        <TextBlock Text="OpenAI API Key" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="OpenAIPwdBox" Grid.Column="0"/>
                            <TextBox x:Name="OpenAITxtBox" Grid.Column="0" Visibility="Collapsed"
                                     Text="{Binding OpenAIApiKey}"/>
                            <Button Grid.Column="1" x:Name="OpenAIReveal" Content="👁 Show"
                                    Style="{StaticResource RevealButton}" Margin="6,0,0,0"
                                    Click="RevealApiKey_Click" Tag="OpenAI"/>
                        </Grid>

                        <!-- OpenRouter -->
                        <TextBlock Text="OpenRouter API Key" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="OpenRouterPwdBox" Grid.Column="0"/>
                            <TextBox x:Name="OpenRouterTxtBox" Grid.Column="0" Visibility="Collapsed"
                                     Text="{Binding OpenRouterApiKey}"/>
                            <Button Grid.Column="1" x:Name="OpenRouterReveal" Content="👁 Show"
                                    Style="{StaticResource RevealButton}" Margin="6,0,0,0"
                                    Click="RevealApiKey_Click" Tag="OpenRouter"/>
                        </Grid>

                        <!-- Cerebras -->
                        <TextBlock Text="Cerebras API Key" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="CerebrasPwdBox" Grid.Column="0"/>
                            <TextBox x:Name="CerebrasTxtBox" Grid.Column="0" Visibility="Collapsed"
                                     Text="{Binding CerebrasApiKey}"/>
                            <Button Grid.Column="1" x:Name="CerebrasReveal" Content="👁 Show"
                                    Style="{StaticResource RevealButton}" Margin="6,0,0,0"
                                    Click="RevealApiKey_Click" Tag="Cerebras"/>
                        </Grid>

                        <Button Content="TEST KEYS" 
                                Command="{Binding TestApiCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,10"
                                Padding="20,8"
                                Background="{DynamicResource AppAccentBrush}"
                                Foreground="Black"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="History" Style="{StaticResource ModernTabItem}">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Recent Transcriptions" Style="{StaticResource FieldLabel}" Grid.Row="0"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding HistoryEntries}" 
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" 
                                                       FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding RefinedText}" TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource AppFgBrush}"/>
                                            <TextBlock Text="{Binding OriginalText}" FontSize="12" Foreground="{DynamicResource AppTextMutedBrush}" 
                                                       FontStyle="Italic" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Button Grid.Column="1" VerticalAlignment="Top" Content="Copy" 
                                                Command="{Binding DataContext.CopyHistoryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding RefinedText}"
                                                Padding="10,5" FontSize="11" Background="{DynamicResource AppControlBorderBrush}" Foreground="{DynamicResource AppFgBrush}" BorderThickness="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource AppFooterBgBrush}" CornerRadius="12"
                Padding="20,10" Margin="0,16,0,0">
            <Grid>
                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource AppTextMutedBrush}"
                           FontSize="12">Speakly · C# .NET 9 · WPF</TextBlock>
                <Button Content="SAVE SETTINGS"
                        Command="{Binding SaveCommand}"
                        Click="SaveButton_Click"
                        HorizontalAlignment="Right"
                        Padding="25,10"
                        Background="{DynamicResource AppAccentBrush}"
                        Foreground="Black"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
