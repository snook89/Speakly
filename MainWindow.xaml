<Window x:Class="Speakly.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Speakly"
    xmlns:pages="clr-namespace:Speakly.Pages"
    Title="{Binding SelectedItem.Content, ElementName=RootNavigation, StringFormat=Speakly - {0}, TargetNullValue=Settings, FallbackValue=Speakly - Settings}"
    Height="760"
    Width="1160"
    MinHeight="680"
    MinWidth="980"
    Icon="Resources/Speakly_new_logo.ico"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    FontFamily="Segoe UI Variable Text">

    <Grid>
        <!-- NavigationView is self-contained: its own pane (left) + content area (right).
             No external Frame needed – pages are navigated directly via RootNavigation.Navigate(). -->
        <ui:NavigationView x:Name="RootNavigation"
                           PaneDisplayMode="Left"
                           PaneTitle="Speakly"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           OpenPaneLength="220"
                           CompactPaneLength="52">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Home"
                                       TargetPageType="{x:Type pages:HomePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="General"
                                       TargetPageType="{x:Type pages:GeneralPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Hotkeys"
                                       TargetPageType="{x:Type pages:HotkeysPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Keyboard20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Audio"
                                       TargetPageType="{x:Type pages:AudioPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Mic20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Transcription"
                                       TargetPageType="{x:Type pages:TranscriptionPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DocumentText20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Refinement"
                                       TargetPageType="{x:Type pages:RefinementPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="EmojiSparkle20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="API Keys"
                                       TargetPageType="{x:Type pages:ApiKeysPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Key20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="History"
                                       TargetPageType="{x:Type pages:HistoryPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="History20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Statistics"
                                       TargetPageType="{x:Type pages:StatisticsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DataHistogram20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Info"
                                       TargetPageType="{x:Type pages:InfoPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>
</Window>
