<Window x:Class="Speakly.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Speakly"
    xmlns:pages="clr-namespace:Speakly.Pages"
    Title="Speakly - Settings"
    Height="760"
    Width="1160"
    MinHeight="680"
    MinWidth="980"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    FontFamily="Segoe UI Variable Text">

    <Window.Resources>
        <!-- Green glow pulse played when settings are saved -->
        <Storyboard x:Key="SaveGlowStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SaveGlowBorder"
                                          Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame Value="1"  KeyTime="0:0:0.15">
                    <EasingDoubleKeyFrame.EasingFunction><CubicEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame Value="1"  KeyTime="0:0:0.55"/>
                <EasingDoubleKeyFrame Value="0"  KeyTime="0:0:1.4">
                    <EasingDoubleKeyFrame.EasingFunction><CubicEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- NavigationView is self-contained: its own pane (left) + content area (right).
             No external Frame needed – pages are navigated directly via RootNavigation.Navigate(). -->
        <ui:NavigationView x:Name="RootNavigation"
                           PaneDisplayMode="Left"
                           PaneTitle="Speakly"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           OpenPaneLength="220"
                           CompactPaneLength="52">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="General"
                                       TargetPageType="{x:Type pages:GeneralPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Hotkeys"
                                       TargetPageType="{x:Type pages:HotkeysPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Keyboard16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Audio"
                                       TargetPageType="{x:Type pages:AudioPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Mic20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Transcription"
                                       TargetPageType="{x:Type pages:TranscriptionPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DocumentText20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Refinement"
                                       TargetPageType="{x:Type pages:RefinementPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="EmojiSparkle20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="API Keys"
                                       TargetPageType="{x:Type pages:ApiKeysPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Key16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="History"
                                       TargetPageType="{x:Type pages:HistoryPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="History16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Info"
                                       TargetPageType="{x:Type pages:InfoPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

            <ui:NavigationView.PaneFooter>
                <ui:Button Content="Save Settings"
                           Command="{Binding SaveCommand}"
                           Margin="8,4,8,12"
                           HorizontalAlignment="Stretch"
                           Appearance="Primary"/>
            </ui:NavigationView.PaneFooter>
        </ui:NavigationView>

        <!-- Green border glow overlay — pointer-transparent, sits above everything -->
        <Border x:Name="SaveGlowBorder"
                BorderThickness="4"
                IsHitTestVisible="False"
                Opacity="0"
                Panel.ZIndex="999">
            <Border.BorderBrush>
                <SolidColorBrush Color="#22C55E"/>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#22C55E" BlurRadius="28" ShadowDepth="0" Opacity="0.9"/>
            </Border.Effect>
        </Border>
    </Grid>
</Window>