<Window x:Class="Speakly.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speakly Setup"
        Width="680"
        Height="560"
        Icon="Resources/Speakly_new_logo.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="StepBadgeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BadgeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BadgeBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BadgeBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#1E293B"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#0F172A"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="NavBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FinishButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="BorderBrush" Value="#0EA5E9"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="WizardTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="WizardPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="WizardComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="IsTextSearchEnabled" Value="False"/>
        </Style>

        <Style x:Key="WizardComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <DataTemplate x:Key="AudioDeviceItemTemplate">
            <TextBlock x:Name="AudioDeviceText" Text="{Binding}" Foreground="#111827"/>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding}" Value="">
                    <Setter TargetName="AudioDeviceText" Property="Text" Value="(Unnamed input device)"/>
                    <Setter TargetName="AudioDeviceText" Property="Foreground" Value="#475569"/>
                    <Setter TargetName="AudioDeviceText" Property="FontStyle" Value="Italic"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="First-Time Setup" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,14">
            <Button x:Name="WelcomeBadge"
                    Tag="0"
                    Click="StepBadge_Click"
                    Background="#1F2937"
                    BorderBrush="#1F2937"
                    Style="{StaticResource StepBadgeButtonStyle}"
                    Content="Welcome"/>
            <Button x:Name="ApiKeysBadge"
                    Tag="1"
                    Click="StepBadge_Click"
                    Background="#4B5563"
                    BorderBrush="#4B5563"
                    Style="{StaticResource StepBadgeButtonStyle}"
                    Content="API Keys"/>
            <Button x:Name="AudioBadge"
                    Tag="2"
                    Click="StepBadge_Click"
                    Background="#4B5563"
                    BorderBrush="#4B5563"
                    Style="{StaticResource StepBadgeButtonStyle}"
                    Content="Audio &amp; Hotkeys"/>
            <Button x:Name="FinishBadge"
                    Tag="3"
                    Click="StepBadge_Click"
                    Background="#4B5563"
                    BorderBrush="#4B5563"
                    Style="{StaticResource StepBadgeButtonStyle}"
                    Margin="0"
                    Content="Finish"/>
        </WrapPanel>

        <Border Grid.Row="2"
                Background="#F7F7F8"
                BorderBrush="#D7D7DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel x:Name="WelcomePanel">
                            <TextBlock Text="Speakly needs a basic setup before first use."
                                       FontSize="15"
                                       Foreground="#101010"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="You can edit all of these settings later from the main app."
                                       Margin="0,10,0,0"
                                       Foreground="#101010"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="ApiKeysPanel" Visibility="Collapsed">
                            <TextBlock Text="Deepgram API Key" Margin="0,0,0,4" Foreground="#101010"/>
                            <PasswordBox x:Name="DeepgramKeyBox" Margin="0,0,0,12" Style="{StaticResource WizardPasswordBoxStyle}"/>
                            <TextBlock Text="OpenAI API Key" Margin="0,0,0,4" Foreground="#101010"/>
                            <PasswordBox x:Name="OpenAIKeyBox" Margin="0,0,0,12" Style="{StaticResource WizardPasswordBoxStyle}"/>
                            <TextBlock Text="Cerebras API Key" Margin="0,0,0,4" Foreground="#101010"/>
                            <PasswordBox x:Name="CerebrasKeyBox" Margin="0,0,0,12" Style="{StaticResource WizardPasswordBoxStyle}"/>
                            <TextBlock Text="OpenRouter API Key" Margin="0,0,0,4" Foreground="#101010"/>
                            <PasswordBox x:Name="OpenRouterKeyBox" Style="{StaticResource WizardPasswordBoxStyle}"/>
                        </StackPanel>

                        <StackPanel x:Name="AudioPanel" Visibility="Collapsed">
                            <TextBlock Text="Push-to-talk hotkey" Margin="0,0,0,4" Foreground="#101010"/>
                            <TextBox x:Name="PttHotkeyBox"
                                     Text="{Binding PttHotkey}"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource WizardTextBoxStyle}"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewMouseLeftButtonDown="HotkeyBox_PreviewMouseLeftButtonDown"/>
                            <TextBlock Text="Toggle recording hotkey" Margin="0,0,0,4" Foreground="#101010"/>
                            <TextBox x:Name="RecordHotkeyBox"
                                     Text="{Binding RecordHotkey}"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource WizardTextBoxStyle}"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewMouseLeftButtonDown="HotkeyBox_PreviewMouseLeftButtonDown"/>
                            <TextBlock x:Name="HotkeyCaptureHint"
                                       Text="Click a hotkey field, then press a key combination (Ctrl/Alt/Shift/Win supported)."
                                       Foreground="#475569"
                                       Margin="0,0,0,10"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Audio device" Margin="0,0,0,4" Foreground="#101010"/>
                            <ComboBox ItemsSource="{Binding AvailableAudioDevices}"
                                      SelectedItem="{Binding AudioDevice}"
                                      Style="{StaticResource WizardComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource WizardComboBoxItemStyle}"
                                      ItemTemplate="{StaticResource AudioDeviceItemTemplate}"/>
                        </StackPanel>

                        <StackPanel x:Name="FinishPanel" Visibility="Collapsed">
                            <TextBlock Text="Ready to go."
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#101010"/>
                            <TextBlock Text="Click Finish to open Speakly."
                                       Margin="0,8,0,0"
                                       Foreground="#101010"/>
                            <TextBlock x:Name="ValidationText"
                                       Foreground="OrangeRed"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <Button Content="Back"
                    Width="90"
                    Click="Back_Click"
                    x:Name="BackButton"
                    Style="{StaticResource NavButtonStyle}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Next"
                        Width="90"
                        Margin="0,0,8,0"
                        Click="Next_Click"
                        x:Name="NextButton"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Finish"
                        Width="90"
                        Click="Finish_Click"
                        x:Name="FinishButton"
                        Style="{StaticResource FinishButtonStyle}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
