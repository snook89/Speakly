<UserControl x:Class="Speakly.Pages.GeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">
            <TextBlock Text="General" Style="{StaticResource PageTitle}"/>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Appearance" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Theme" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValue="{Binding Theme}" SelectedValuePath="Content" Margin="0,0,0,6" MaxWidth="300" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>
                    <TextBlock Text="Overlay Skin" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding AvailableOverlaySkins}"
                              SelectedItem="{Binding OverlaySkin}"
                              Margin="0,0,0,6"
                              MaxWidth="300"
                              HorizontalAlignment="Left"/>
                    <TextBlock Text="Theme changes apply instantly." Style="{StaticResource HintText}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Behavior" Style="{StaticResource SectionTitle}"/>
                    <ui:ToggleSwitch Content="Show Floating Overlay" IsChecked="{Binding ShowOverlay}" Margin="0,0,0,10"/>
                    <ui:ToggleSwitch Content="Minimize to Tray on Close" IsChecked="{Binding MinimizeToTray}" Margin="0,0,0,10"/>

                    <TextBlock Text="Insertion Reliability" Style="{StaticResource FieldLabel}" Margin="0,14,0,6"/>
                    <TextBlock Text="{Binding LastInsertionStatus}" Style="{StaticResource HintText}"/>
                    <TextBlock Text="{Binding LastInsertionMethod, StringFormat=Method: {0}}" Style="{StaticResource HintText}"/>

                    <Expander Header="Advanced Settings" IsExpanded="False" Margin="0,12,0,0">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="For power users. Defaults are safe for most setups."
                                       Style="{StaticResource HintText}"
                                       Margin="0,0,0,10"/>

                            <ui:ToggleSwitch Content="Copy result to clipboard" IsChecked="{Binding CopyToClipboard}" Margin="0,0,0,10"/>
                            <TextBlock Text="After each transcription the final text is also placed on the clipboard, so you can Ctrl+V it anywhere even if the target window was not focused." Style="{StaticResource HintText}" Margin="0,0,0,10"/>
                            <ui:ToggleSwitch Content="Enable STT failover on transient errors" IsChecked="{Binding EnableSttFailover}" Margin="0,0,0,10"/>
                            <ui:ToggleSwitch Content="Enable Debug Logs" IsChecked="{Binding EnableDebugLogs}" Margin="0,0,0,14"/>

                            <TextBlock Text="Telemetry" Style="{StaticResource FieldLabel}"/>
                            <ui:ToggleSwitch Content="Enable Local Telemetry" IsChecked="{Binding TelemetryEnabled}" Margin="0,0,0,10"/>
                            <TextBlock Text="Telemetry is stored locally only and is redacted by default." Style="{StaticResource HintText}" Margin="0,0,0,10"/>

                            <TextBlock Text="Telemetry Level" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding AvailableTelemetryLevels}"
                                      SelectedItem="{Binding TelemetryLevel}"
                                      Margin="0,0,0,10"
                                      MaxWidth="240"
                                      HorizontalAlignment="Left"/>
                            <TextBlock Text="Redaction Mode" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding AvailableTelemetryRedactionModes}"
                                      SelectedItem="{Binding TelemetryRedactionMode}"
                                      Margin="0,0,0,10"
                                      MaxWidth="240"
                                      HorizontalAlignment="Left"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Retention (days)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding TelemetryRetentionDays, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Max file (MB)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="4" Text="{Binding TelemetryMaxFileMb, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
