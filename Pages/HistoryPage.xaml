<UserControl x:Class="Speakly.Pages.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text"
             Background="#FF1E2330">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="860">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="ACTIVITY" Style="{StaticResource PageEyebrow}" />
                <TextBlock Text="History" Style="{StaticResource PageTitle}" Margin="0" />
            </StackPanel>

            <Border Style="{StaticResource PageFeatureCard}">
                <StackPanel>
                    <TextBlock Text="FILTERS" Style="{StaticResource PageFeatureLabel}" />
                    <Border Style="{StaticResource PageFeatureSurface}" Margin="0">
                        <Grid Margin="0,0,0,2"
                              HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="SearchBox"
                                        Grid.Column="0"
                                        PlaceholderText="Search history..."
                                        TextChanged="SearchBox_TextChanged"
                                        Style="{StaticResource InputDefault}"
                                        Width="150"
                                        Margin="0,0,12,0" />
                            <ComboBox x:Name="StatusFilterBox"
                                      Grid.Column="1"
                                      SelectionChanged="Filter_SelectionChanged"
                                      Style="{StaticResource DropdownDefault}"
                                      Width="141"
                                      MinWidth="0"
                                      Margin="0,0,12,0">
                                <ComboBoxItem Content="All statuses" Tag="all" />
                                <ComboBoxItem Content="Successful" Tag="ok" />
                                <ComboBoxItem Content="Failed" Tag="fail" />
                            </ComboBox>
                            <ComboBox x:Name="ProviderFilterBox"
                                      Grid.Column="2"
                                      SelectionChanged="Filter_SelectionChanged"
                                      Style="{StaticResource DropdownDefault}"
                                      Width="141"
                                      MinWidth="0"
                                      Margin="0,0,12,0">
                                <ComboBoxItem Content="All providers" Tag="all" />
                                <ComboBoxItem Content="Deepgram" Tag="Deepgram" />
                                <ComboBoxItem Content="ElevenLabs" Tag="ElevenLabs" />
                                <ComboBoxItem Content="OpenAI" Tag="OpenAI" />
                                <ComboBoxItem Content="OpenRouter" Tag="OpenRouter" />
                            </ComboBox>
                            <ComboBox x:Name="ProfileFilterBox"
                                      Grid.Column="3"
                                      SelectionChanged="Filter_SelectionChanged"
                                      Style="{StaticResource DropdownDefault}"
                                      Width="141"
                                      MinWidth="0">
                                <ComboBoxItem Content="All profiles" Tag="all" />
                            </ComboBox>
                            <ComboBox x:Name="ActionFilterBox"
                                      Grid.Column="4"
                                      SelectionChanged="Filter_SelectionChanged"
                                      Style="{StaticResource DropdownDefault}"
                                      Width="141"
                                      MinWidth="0"
                                      Margin="12,0,12,0">
                                <ComboBoxItem Content="All actions" Tag="all" />
                                <ComboBoxItem Content="Live" Tag="Live" />
                                <ComboBoxItem Content="History retry" Tag="HistoryRetry" />
                                <ComboBoxItem Content="History reprocess" Tag="HistoryReprocess" />
                            </ComboBox>
                            <ComboBox x:Name="PinFilterBox"
                                      Grid.Column="5"
                                      SelectionChanged="Filter_SelectionChanged"
                                      Style="{StaticResource DropdownDefault}"
                                      Width="141"
                                      MinWidth="0">
                                <ComboBoxItem Content="All entries" Tag="all" />
                                <ComboBoxItem Content="Pinned only" Tag="pinned" />
                                <ComboBoxItem Content="Unpinned only" Tag="unpinned" />
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageFeatureCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="ENTRIES" Style="{StaticResource PageFeatureLabel}" />
                    <ListBox ItemsSource="{Binding HistoryEntries}"
                             Style="{StaticResource InputList}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PageFeatureSurface}" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                       Style="{StaticResource HintText}"
                                                       Margin="0,0,0,4" />
                                            <WrapPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding SttProvider, StringFormat=STT: {0}}" Style="{StaticResource HintText}" Margin="0,0,14,0" />
                                                <TextBlock Text="{Binding RefinementProvider, StringFormat=Refinement: {0}}" Style="{StaticResource HintText}" Margin="0,0,14,0" />
                                                <TextBlock Text="{Binding DictationMode, StringFormat=Mode: {0}}" Style="{StaticResource HintText}" Margin="0,0,14,0" />
                                                <TextBlock Text="{Binding ContextualRefinementMode, StringFormat=Context Mode: {0}}" Style="{StaticResource HintText}" Margin="0,0,14,0" />
                                                <TextBlock Text="{Binding DisplayActionLabel, StringFormat=Action: {0}}" Style="{StaticResource HintText}" Margin="0,0,14,0" />
                                                <TextBlock Text="{Binding Succeeded, StringFormat=Successful: {0}}" Style="{StaticResource HintText}" Margin="0,0,14,0" />
                                                <TextBlock Text="{Binding ProfileName, StringFormat=Profile: {0}}" Style="{StaticResource HintText}" Margin="0,0,14,0" />
                                                <TextBlock Text="{Binding FailoverAttempted, StringFormat=Failover: {0}}" Style="{StaticResource HintText}" />
                                            </WrapPanel>

                                            <TextBlock Text="{Binding DisplayPrimaryLabel}"
                                                       Style="{StaticResource PageFeatureLabel}"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding DisplayPrimaryText}"
                                                       Style="{StaticResource BodyText}"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding DisplaySecondaryLabel}"
                                                       Style="{StaticResource PageFeatureLabel}"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding DisplaySecondaryText}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding ContextSummary, StringFormat=Context: {0}}"
                                                       Margin="0,0,0,8">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource HintText}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasContextSummary}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <Border Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource PageFeatureSurface}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSourceComparison}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding CompareLabel}"
                                                               Style="{StaticResource PageFeatureLabel}"
                                                               Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding CompareSourceText}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource BrushTextSecondary}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding CompareSummary}"
                                                               Style="{StaticResource HintText}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <UniformGrid Columns="4">
                                                <Border Style="{StaticResource PageFeatureSurface}" Margin="0,0,8,0">
                                                    <StackPanel>
                                                        <TextBlock Text="RECORD" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                                        <TextBlock Text="{Binding RecordMs, StringFormat={}{0} ms}" Style="{StaticResource BodyText}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource PageFeatureSurface}" Margin="0,0,8,0">
                                                    <StackPanel>
                                                        <TextBlock Text="TRANSCRIBE" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                                        <TextBlock Text="{Binding TranscribeMs, StringFormat={}{0} ms}" Style="{StaticResource BodyText}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource PageFeatureSurface}" Margin="0,0,8,0">
                                                    <StackPanel>
                                                        <TextBlock Text="REFINE" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                                        <TextBlock Text="{Binding RefineMs, StringFormat={}{0} ms}" Style="{StaticResource BodyText}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource PageFeatureSurface}" Margin="0">
                                                    <StackPanel>
                                                        <TextBlock Text="INSERT" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                                        <TextBlock Text="{Binding InsertMs, StringFormat={}{0} ms}" Style="{StaticResource BodyText}" />
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="12,0,0,0">
                                            <ui:Button Content="Copy Refined"
                                                       Command="{Binding DataContext.CopyHistoryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       CommandParameter="{Binding}"
                                                       Style="{StaticResource GhostButton}"
                                                       Margin="0,0,0,8" />
                                            <ui:Button Content="Copy Original"
                                                       Command="{Binding DataContext.CopyOriginalHistoryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       CommandParameter="{Binding}"
                                                       Style="{StaticResource GhostButton}"
                                                       Margin="0,0,0,8" />
                                            <ui:Button Content="Retry Insert"
                                                       Command="{Binding DataContext.RetryHistoryInsertCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       CommandParameter="{Binding}"
                                                       Style="{StaticResource SecondaryButton}"
                                                       Margin="0,0,0,8" />
                                            <ui:Button Content="Reprocess"
                                                       Command="{Binding DataContext.ReprocessHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       CommandParameter="{Binding}"
                                                       Style="{StaticResource SecondaryButton}"
                                                       Margin="0,0,0,8" />
                                            <ui:Button Content="Pin"
                                                       Command="{Binding DataContext.TogglePinnedHistoryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       CommandParameter="{Binding}"
                                                       Style="{StaticResource GhostButton}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>


