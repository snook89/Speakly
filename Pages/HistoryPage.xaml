<UserControl x:Class="Speakly.Pages.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text">
    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="History" Style="{StaticResource PageTitle}"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox x:Name="SearchBox"
                        Grid.Column="0"
                        PlaceholderText="Search history..."
                        TextChanged="SearchBox_TextChanged"
                        Margin="0,0,8,0"/>
            <ComboBox x:Name="StatusFilterBox"
                      Grid.Column="1"
                      SelectionChanged="Filter_SelectionChanged"
                      Width="130"
                      Margin="0,0,8,0">
                <ComboBoxItem Content="All statuses" Tag="all"/>
                <ComboBoxItem Content="Successful" Tag="ok"/>
                <ComboBoxItem Content="Failed" Tag="fail"/>
            </ComboBox>
            <ComboBox x:Name="ProviderFilterBox"
                      Grid.Column="2"
                      SelectionChanged="Filter_SelectionChanged"
                      Width="130">
                <ComboBoxItem Content="All providers" Tag="all"/>
                <ComboBoxItem Content="Deepgram" Tag="Deepgram"/>
                <ComboBoxItem Content="OpenAI" Tag="OpenAI"/>
                <ComboBoxItem Content="OpenRouter" Tag="OpenRouter"/>
            </ComboBox>
            <ComboBox x:Name="ProfileFilterBox"
                      Grid.Column="3"
                      SelectionChanged="Filter_SelectionChanged"
                      Width="150"
                      Margin="8,0,0,0">
                <ComboBoxItem Content="All profiles" Tag="all"/>
            </ComboBox>
        </Grid>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding HistoryEntries}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ui:Card Padding="12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SttProvider, StringFormat=STT: {0}}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding Succeeded, StringFormat=Successful: {0}}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ProfileName, StringFormat=Profile: {0}}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding FailoverAttempted, StringFormat=Failover: {0}}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding RefinedText}"
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{Binding OriginalText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontStyle="Italic"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding RecordMs, StringFormat=Record: {0} ms}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding TranscribeMs, StringFormat=Transcribe: {0} ms}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding RefineMs, StringFormat=Refine: {0} ms}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding InsertMs, StringFormat=Insert: {0} ms}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <ui:Button Grid.Column="1"
                                       VerticalAlignment="Top"
                                       Content="Copy"
                                       Command="{Binding DataContext.CopyHistoryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                       CommandParameter="{Binding RefinedText}"
                                       Padding="10,5"
                                       FontSize="11"
                                       Style="{StaticResource SecondaryButton}"/>
                        </Grid>
                    </ui:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
