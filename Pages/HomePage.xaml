<UserControl x:Class="Speakly.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">
            <TextBlock Text="Home" Style="{StaticResource PageTitle}"/>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Session Status" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="{Binding ActiveProfileName, StringFormat=Active profile: {0}}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding LastInsertionStatus}" Style="{StaticResource HintText}" Margin="0,2,0,2"/>
                    <TextBlock Text="{Binding LastInsertionMethod, StringFormat=Insertion method: {0}}" Style="{StaticResource HintText}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Quick Actions" Style="{StaticResource SectionTitle}"/>
                    <WrapPanel>
                        <ui:Button Content="Run health checks"
                                   Command="{Binding RunHealthCheckCommand}"
                                   Margin="0,0,8,8"
                                   Style="{StaticResource SecondaryButton}"/>
                        <ui:Button Content="Refresh models"
                                   Command="{Binding RefreshModelsCommand}"
                                   Margin="0,0,8,8"
                                   Style="{StaticResource SecondaryButton}"/>
                        <ui:Button Content="Toggle refinement"
                                   Command="{Binding ToggleRefinementQuickCommand}"
                                   Margin="0,0,8,8"
                                   Style="{StaticResource SecondaryButton}"/>
                        <ui:Button Content="Next profile"
                                   Command="{Binding CycleProfileCommand}"
                                   Margin="0,0,8,8"
                                   Style="{StaticResource SecondaryButton}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Profiles" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Create multiple profiles and map them to app process names (example: code, notepad)."
                               Style="{StaticResource HintText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Active Profile" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,10"
                              MaxWidth="360"
                              HorizontalAlignment="Left"/>

                    <WrapPanel Margin="0,0,0,10">
                        <ui:Button Content="Next profile"
                                   Command="{Binding CycleProfileCommand}"
                                   Margin="0,0,8,8"
                                   Style="{StaticResource SecondaryButton}"/>
                        <ui:Button Content="Save profile"
                                   Command="{Binding SaveProfileCommand}"
                                   Margin="0,0,8,8"
                                   Style="{StaticResource PrimaryButton}"/>
                        <ui:Button Content="Delete selected profile"
                                   Command="{Binding DeleteProfileCommand}"
                                   Margin="0,0,8,8"
                                   Style="{StaticResource SecondaryButton}"
                                   IsEnabled="{Binding CanDeleteSelectedProfile}"/>
                    </WrapPanel>

                    <TextBlock Text="Profile Name" Style="{StaticResource FieldLabel}"/>
                    <ui:TextBox Text="{Binding ProfileDraftName, UpdateSourceTrigger=PropertyChanged}"
                               Margin="0,0,0,10"
                               MaxWidth="420"
                               HorizontalAlignment="Left"/>

                    <TextBlock Text="Process Names for Auto-Selection" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ProfileProcessNamesInput, UpdateSourceTrigger=PropertyChanged}"
                             Height="70"
                             Margin="0,0,0,4"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                    <TextBlock Text="Separate names by comma/newline. Include process name only (for example: code, chrome, notepad)."
                               Style="{StaticResource HintText}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Create New Profile" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                   Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                   PlaceholderText="Profile name (optional)"
                                   Margin="0,0,8,0"/>
                        <ui:Button Grid.Column="1"
                                   Content="Create profile"
                                   Command="{Binding CreateProfileCommand}"
                                   Style="{StaticResource SecondaryButton}"/>
                    </Grid>

                    <TextBlock Text="{Binding ProfileStatusMessage}"
                               Style="{StaticResource HintText}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Startup Health" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="{Binding HealthSummary}" Style="{StaticResource HintText}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding HealthDetails}" Style="{StaticResource HintText}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
