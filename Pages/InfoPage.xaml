<UserControl x:Class="Speakly.Pages.InfoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text"
             Background="#FF1E2330">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="ABOUT" Style="{StaticResource PageEyebrow}" />
                <TextBlock Text="Info" Style="{StaticResource PageTitle}" Margin="0" />
            </StackPanel>

            <TextBlock Text="Speech-to-text capture with optional AI refinement, built for fast keyboard-first workflows."
                       Style="{StaticResource HintText}"
                       Margin="0,0,0,18" />

            <Border CornerRadius="12"
                    ClipToBounds="True"
                    Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BrushBorderSubtle}"
                    BorderThickness="1">
                <Image Source="pack://application:,,,/Resources/Speakly_banner.png"
                       Stretch="UniformToFill"
                       MaxHeight="200" />
            </Border>

            <Border Style="{StaticResource PageFeatureCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="APPLICATION" Style="{StaticResource PageFeatureLabel}" />
                        <TextBlock Text="Current Version" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="VersionText"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}" />
                        <TextBlock x:Name="BuildText"
                                   Text=".NET 9 · WPF UI 4.2 · Windows 10/11"
                                   Style="{StaticResource HintText}"
                                   Margin="0,6,0,0" />
                        <TextBlock x:Name="UpdateStatusText"
                                   Text="Automatic update check runs shortly after startup."
                                   Style="{StaticResource HintText}"
                                   Margin="0,12,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Width="250">
                        <ui:Button x:Name="CheckUpdatesButton"
                                   Content="Check for Updates Now"
                                   Style="{StaticResource PrimaryButton}"
                                   Margin="0,0,0,8"
                                   Click="CheckUpdatesButton_Click" />
                        <ui:Button x:Name="ReleasesButton"
                                   Content="Open Releases"
                                   Style="{StaticResource SecondaryButton}"
                                   Margin="0,0,0,8"
                                   Click="ReleasesButton_Click" />
                        <ui:Button x:Name="GitHubButton"
                                   Content="Open on GitHub"
                                   Style="{StaticResource GhostButton}"
                                   Click="GitHubButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource PageFeatureCard}">
                <StackPanel>
                    <TextBlock Text="OVERVIEW" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Overview" Style="{StaticResource SectionTitle}" />
                    <TextBlock Style="{StaticResource BodyText}">
                        Speakly is a lightweight Windows utility for real-time speech-to-text transcription with optional AI text refinement.
                        Press a configurable hotkey to record your voice, and the transcribed text is inserted where your cursor is.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageFeatureCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="UPDATES" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Update Behavior" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="1. On startup, Speakly checks GitHub Releases for newer versions."
                               Style="{StaticResource HintText}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="2. If a newer release exists, it is downloaded in the background."
                               Style="{StaticResource HintText}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="3. Speakly prompts for restart to apply the update."
                               Style="{StaticResource HintText}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>


