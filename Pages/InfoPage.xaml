<UserControl x:Class="Speakly.Pages.InfoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Speakly"
             FontFamily="Segoe UI Variable Text">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24" MaxWidth="680" HorizontalAlignment="Left">
            <TextBlock Text="About Speakly" Style="{StaticResource PageTitle}"/>

            <!-- Banner -->
            <Border CornerRadius="12" ClipToBounds="True" Margin="0,0,0,24">
                <Image Source="pack://application:,,,/Resources/Speakly_banner.png"
                       Stretch="UniformToFill"
                       MaxHeight="200"/>
            </Border>

            <!-- Version card -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Version" Style="{StaticResource SectionTitle}"/>
                    <TextBlock x:Name="VersionText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text=".NET 9 · WPF UI 4.2 · Windows 10/11"
                               Style="{StaticResource HintText}"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Links card -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Links" Style="{StaticResource SectionTitle}"/>
                    <ui:Button x:Name="GitHubButton"
                               Content="⭐  Open on GitHub"
                               HorizontalAlignment="Left"
                               Appearance="Secondary"
                               Padding="16,10"
                               FontSize="14"
                               Click="GitHubButton_Click"/>
                    <TextBlock Text="Source code, releases, and issue tracker."
                               Style="{StaticResource HintText}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Description card -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Description" Style="{StaticResource SectionTitle}"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="14"
                               LineHeight="22"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        Speakly is a lightweight Windows utility for real-time speech-to-text transcription
                        with optional AI text refinement. Press a configurable hotkey to record your voice,
                        and the transcribed (and optionally refined) text is automatically inserted wherever
                        your cursor is.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
