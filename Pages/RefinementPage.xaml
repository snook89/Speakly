<UserControl x:Class="Speakly.Pages.RefinementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">
            <TextBlock Text="Refinement" Style="{StaticResource PageTitle}"/>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="AI Text Refinement" Style="{StaticResource SectionTitle}"/>

                    <ui:ToggleSwitch Content="Enable AI Refinement" IsChecked="{Binding EnableRefinement}" Margin="0,0,0,16"/>

                    <!-- All refinement settings are hidden when refinement is disabled -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EnableRefinement}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                    <TextBlock Text="Service" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValue="{Binding RefinementModel}" SelectedValuePath="Content" Margin="0,0,0,16" MaxWidth="300" HorizontalAlignment="Left">
                        <ComboBoxItem Content="OpenAI"/>
                        <ComboBoxItem Content="OpenRouter"/>
                        <ComboBoxItem Content="Cerebras"/>
                    </ComboBox>

                    <TextBlock Text="Target Model" Style="{StaticResource FieldLabel}"/>
                    <Grid x:Name="ModelRow">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="RefinementModelCombo"
                                  Grid.Column="0"
                                  ItemsSource="{Binding AvailableRefinementModels}"
                                  Text="{Binding SelectedRefinementModelString}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                                  TextChanged="ModelCombo_TextChanged"
                                  DropDownClosed="ModelCombo_DropDownClosed"
                                  PreviewKeyDown="ModelCombo_PreviewKeyDown"
                                  Margin="0,0,8,12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,6,0">
                                            <TextBlock.Visibility>
                                                <MultiBinding Converter="{StaticResource ModelFavoriteVisibilityConverter}"
                                                              ConverterParameter="Refinement">
                                                    <Binding />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext"/>
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                        <TextBlock Text="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                    <!-- Tag carries the ViewModel so ContextMenu can reach it -->
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="★ Toggle Favorite"
                                                          Command="{Binding PlacementTarget.Tag.ToggleRefinementFavoriteModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        <ui:Button Grid.Column="1"
                                   Content="Top"
                                   Style="{StaticResource SecondaryButton}"
                                   Click="JumpToTop_Click"
                                   Margin="0,0,0,12"/>
                        <Border x:Name="ModelGlow"
                                Grid.ColumnSpan="2"
                                BorderThickness="2" IsHitTestVisible="False" Opacity="0" Panel.ZIndex="10"
                                Margin="0,0,0,12">
                            <Border.Effect><DropShadowEffect x:Name="ModelGlowFx" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/></Border.Effect>
                        </Border>
                    </Grid>

                    <ui:Button Content="Refresh models"
                               Command="{Binding RefreshModelsCommand}"
                               HorizontalAlignment="Left"
                               Padding="14,7"
                               Style="{StaticResource SecondaryButton}"
                               Margin="0,0,0,10"/>

                    <ui:InfoBar Title="Model status"
                                Message="{Binding ModelRefreshStatus}"
                                Severity="Informational"
                                IsOpen="{Binding HasModelRefreshStatus}"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="Prompt Presets" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding SavedPrompts}"
                                  SelectedItem="{Binding SelectedPromptEntry}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,8,0"/>
                        <ui:Button Grid.Column="1"
                                   Content="Delete"
                                   Command="{Binding DeleteSelectedPromptCommand}"
                                   Style="{StaticResource SecondaryButton}"
                                   IsEnabled="{Binding CanDeleteSelectedPrompt}"
                                   ToolTip="Delete selected user prompt (built-in prompts cannot be deleted)"/>
                    </Grid>

                    <ui:InfoBar Title="Prompt warning"
                                Message="Custom System Prompt is empty. Refinement may behave unpredictably."
                                Severity="Warning"
                                IsOpen="{Binding IsRefinementPromptMissing}"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="Custom System Prompt" Style="{StaticResource FieldLabel}"/>
                    <ui:TextBox x:Name="PromptTextBox"
                                Text="{Binding RefinementPrompt, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" Height="160" TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="Save current prompt as:" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    PlaceholderText="Prompt name…"
                                    Text="{Binding NewPromptName, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,8,0"/>
                        <ui:Button Grid.Column="1"
                                   Content="Save"
                                   Command="{Binding SaveCurrentPromptCommand}"
                                   Style="{StaticResource SecondaryButton}"
                                   ToolTip="Save the current prompt text under this name"/>
                    </Grid>
                    <TextBlock Text="Built-in prompts (General, Ukrainian) cannot be overwritten or deleted."
                               Style="{StaticResource HintText}" Margin="0,0,0,4"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
