<UserControl x:Class="Speakly.Pages.RefinementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">
            <TextBlock Text="Refinement" Style="{StaticResource PageTitle}"/>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="AI Text Refinement" Style="{StaticResource SectionTitle}"/>

                    <TextBlock Text="Service" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValue="{Binding RefinementModel}" SelectedValuePath="Content" Margin="0,0,0,16" MaxWidth="300" HorizontalAlignment="Left">
                        <ComboBoxItem Content="OpenAI"/>
                        <ComboBoxItem Content="OpenRouter"/>
                        <ComboBoxItem Content="Cerebras"/>
                    </ComboBox>

                    <TextBlock Text="Target Model" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding AvailableRefinementModels}"
                              Text="{Binding SelectedRefinementModelString}"
                              IsEditable="True"
                              Margin="0,0,0,14">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                <!-- Tag carries the ViewModel so ContextMenu can reach it -->
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="★ Toggle Favorite (OpenRouter)"
                                                      Command="{Binding PlacementTarget.Tag.ToggleFavoriteModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <TextBlock Text="Prompt Presets" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <ui:Button Content="General"
                                   Command="{Binding ApplyRefinementPromptPresetCommand}"
                                   CommandParameter="GENERAL"
                                   Style="{StaticResource SecondaryButton}"/>
                        <ui:Button Content="Ukrainian"
                                   Command="{Binding ApplyRefinementPromptPresetCommand}"
                                   CommandParameter="UK"
                                   Style="{StaticResource SecondaryButton}"
                                   Margin="8,0,0,0"/>
                        <ui:Button Content="Clear"
                                   Command="{Binding ClearRefinementPromptCommand}"
                                   Style="{StaticResource SecondaryButton}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <ui:InfoBar Title="Prompt warning"
                                Message="Custom System Prompt is empty. Refinement may behave unpredictably."
                                Severity="Warning"
                                IsOpen="{Binding IsRefinementPromptMissing}"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="Custom System Prompt" Style="{StaticResource FieldLabel}"/>
                    <ui:TextBox Text="{Binding RefinementPrompt}" AcceptsReturn="True" Height="160" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
