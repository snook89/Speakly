<UserControl x:Class="Speakly.Pages.StatisticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text"
             Background="#FF1E2330">
    <UserControl.Resources>
        <Style x:Key="StatsCenteredHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatsCenteredCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="860">
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="ANALYTICS" Style="{StaticResource PageEyebrow}" />
                <TextBlock Text="Statistics" Style="{StaticResource PageTitle}" Margin="0" />
            </StackPanel>

            <Border Style="{StaticResource PageFeatureCard}">
                <StackPanel>
                    <TextBlock Text="RANGE" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Range" Style="{StaticResource SectionTitle}" />
                    <ComboBox x:Name="RangeCombo"
                              SelectionChanged="RangeCombo_SelectionChanged"
                              Width="220"
                              Style="{StaticResource DropdownDefault}"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="Today" Tag="1" />
                        <ComboBoxItem Content="Last 7 days" Tag="7" />
                        <ComboBoxItem Content="Last 30 days" Tag="30" />
                    </ComboBox>
                    <TextBlock x:Name="SummaryText" Style="{StaticResource HintText}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageFeatureCard}">
                <StackPanel>
                    <TextBlock Text="LATENCY" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Stage Latency Averages" Style="{StaticResource SectionTitle}" />

                    <UniformGrid Columns="4" Margin="0,6,0,0">
                        <Border Style="{StaticResource PageFeatureSurface}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="RECORD" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                <TextBlock x:Name="RecordLatencyText" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                                <TextBlock Text="ms" Style="{StaticResource PageFeatureHint}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PageFeatureSurface}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="TRANSCRIBE" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                <TextBlock x:Name="TranscribeLatencyText" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}" />
                                <TextBlock Text="ms" Style="{StaticResource PageFeatureHint}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PageFeatureSurface}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="REFINE" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                <TextBlock x:Name="RefineLatencyText" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                                <TextBlock Text="ms" Style="{StaticResource PageFeatureHint}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PageFeatureSurface}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="INSERT" Style="{StaticResource PageFeatureLabel}" Margin="0,0,0,4" />
                                <TextBlock x:Name="InsertLatencyText" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                                <TextBlock Text="ms" Style="{StaticResource PageFeatureHint}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <TextBlock x:Name="FailoverText" Style="{StaticResource HintText}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageFeatureCard}">
                <StackPanel>
                    <TextBlock Text="ERRORS" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Top Errors" Style="{StaticResource SectionTitle}" />
                    <TextBlock x:Name="ErrorText" Style="{StaticResource HintText}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageFeatureCard}">
                <StackPanel>
                    <TextBlock Text="TELEMETRY" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Telemetry" Style="{StaticResource SectionTitle}" />
                    <TextBlock x:Name="TelemetrySummaryText" Style="{StaticResource HintText}" />
                    <TextBlock x:Name="TelemetrySessionText" Style="{StaticResource HintText}" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageFeatureCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="PROVIDERS" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Provider Breakdown" Style="{StaticResource SectionTitle}" />
                    <DataGrid x:Name="ProviderList"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              CanUserResizeColumns="False"
                              CanUserReorderColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              BorderThickness="0"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="*" />
                            <DataGridTextColumn Header="Sessions"
                                                Binding="{Binding Sessions}"
                                                Width="90"
                                                HeaderStyle="{StaticResource StatsCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource StatsCenteredCellTextStyle}" />
                            <DataGridTextColumn Header="Successes"
                                                Binding="{Binding Successes}"
                                                Width="100"
                                                HeaderStyle="{StaticResource StatsCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource StatsCenteredCellTextStyle}" />
                            <DataGridTextColumn Header="Success Rate"
                                                Binding="{Binding SuccessRateText}"
                                                Width="120"
                                                HeaderStyle="{StaticResource StatsCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource StatsCenteredCellTextStyle}" />
                            <DataGridTextColumn Header="Avg Latency"
                                                Binding="{Binding AvgLatencyText}"
                                                Width="120"
                                                HeaderStyle="{StaticResource StatsCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource StatsCenteredCellTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>


