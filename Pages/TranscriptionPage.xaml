<UserControl x:Class="Speakly.Pages.TranscriptionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontFamily="Segoe UI Variable Text"
             Background="#FF1E2330">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="760">
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="SPEECH TO TEXT" Style="{StaticResource PageEyebrow}" />
                <TextBlock Text="Transcription" Style="{StaticResource PageTitle}" Margin="0" />
            </StackPanel>

            <Border Style="{StaticResource PageFeatureCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="SPEECH ENGINE" Style="{StaticResource PageFeatureLabel}" />
                    <TextBlock Text="Speech-to-Text" Style="{StaticResource SectionTitle}" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="210" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,24,0">
                            <TextBlock Text="Service" Style="{StaticResource FieldLabel}" />
                            <ComboBox SelectedValue="{Binding SttModel}"
                                      SelectedValuePath="Content"
                                      Style="{StaticResource DropdownDefault}"
                                      Margin="0,0,0,16"
                                      MaxWidth="300"
                                      MinWidth="240"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem Content="Deepgram" />
                                <ComboBoxItem Content="ElevenLabs" />
                                <ComboBoxItem Content="OpenAI" />
                                <ComboBoxItem Content="OpenRouter" />
                            </ComboBox>

                            <TextBlock Text="Language (ISO code)" Style="{StaticResource FieldLabel}" />
                            <ui:TextBox Text="{Binding Language}"
                                        Style="{StaticResource InputDefault}"
                                        Margin="0,0,0,4"
                                        MaxWidth="300"
                                        HorizontalAlignment="Left" />
                            <TextBlock Text="Examples: en, uk, es. Use layout to follow the keyboard layout. Use multi for multilingual mode."
                                       Style="{StaticResource HintText}"
                                       Margin="0,0,0,14" />

                            <ui:InfoBar Title="Deepgram language warning"
                                        Message="{Binding DeepgramLanguageGuardMessage}"
                                        Severity="Warning"
                                        IsOpen="{Binding HasDeepgramLanguageGuard}"
                                        Margin="0,0,0,14" />

                            <TextBlock Text="Target Model" Style="{StaticResource FieldLabel}" />
                            <Grid x:Name="ModelRow" Width="420" HorizontalAlignment="Left">
                                <ComboBox x:Name="SttModelCombo"
                                          ItemsSource="{Binding AvailableSttModels}"
                                          Text="{Binding SelectedSttModelString}"
                                          Style="{StaticResource DropdownDefault}"
                                          Width="420"
                                          HorizontalAlignment="Stretch"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          StaysOpenOnEdit="True"
                                          MaxDropDownHeight="460"
                                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                                          KeyUp="ModelCombo_KeyUp"
                                          DropDownOpened="ModelCombo_DropDownOpened"
                                          DropDownClosed="ModelCombo_DropDownClosed"
                                          PreviewKeyDown="ModelCombo_PreviewKeyDown"
                                          Margin="0,0,0,12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★"
                                                           Foreground="{DynamicResource BrushTextSecondary}"
                                                           Margin="0,0,6,0">
                                                    <TextBlock.Visibility>
                                                        <MultiBinding Converter="{StaticResource ModelFavoriteVisibilityConverter}"
                                                                      ConverterParameter="Stt">
                                                            <Binding />
                                                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext" />
                                                        </MultiBinding>
                                                    </TextBlock.Visibility>
                                                </TextBlock>
                                                <TextBlock Text="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu>
                                                        <MenuItem Header="★ Toggle Favorite"
                                                                  Command="{Binding PlacementTarget.Tag.ToggleSttFavoriteModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                <Border x:Name="ModelGlow"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        IsHitTestVisible="False"
                                        Opacity="0"
                                        Panel.ZIndex="10"
                                        Width="{Binding ElementName=SttModelCombo, Path=ActualWidth}"
                                        Height="{Binding ElementName=SttModelCombo, Path=ActualHeight}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="0,0,0,12">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="ModelGlowFx" BlurRadius="18" ShadowDepth="0" Opacity="0.95" />
                                    </Border.Effect>
                                </Border>
                            </Grid>

                            <StackPanel Margin="0,0,0,10">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOpenRouterSttProvider}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:ToggleSwitch Content="Experimental: show all OpenRouter models"
                                                 IsChecked="{Binding OpenRouterSttShowAllModels}"
                                                 Style="{StaticResource AccentToggleSwitch}" />
                                <TextBlock Text="Includes non-STT models. Some selections may fail transcription requests."
                                           Style="{StaticResource HintText}"
                                           Margin="0,6,0,0" />
                            </StackPanel>

                            <ui:Button Content="Refresh models"
                                       Command="{Binding RefreshModelsCommand}"
                                       HorizontalAlignment="Left"
                                       Style="{StaticResource SecondaryButton}"
                                       Margin="0,0,0,10" />

                            <ui:InfoBar Title="Model status"
                                        Message="{Binding ModelRefreshStatus}"
                                        Severity="Informational"
                                        IsOpen="{Binding HasModelRefreshStatus}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                MinWidth="180"
                                MaxWidth="210"
                                Padding="12"
                                CornerRadius="14"
                                BorderBrush="#2AFFFFFF"
                                BorderThickness="1"
                                Background="#141B2432">
                            <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasProviderBalanceSupport}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Stroke="#8B95A7"
                                                 StrokeThickness="1.5"
                                                 Margin="0,2,6,0"
                                                 VerticalAlignment="Top" />
                                        <TextBlock Text="Balance"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushTextPrimary}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="#FF9E2222"
                                            CornerRadius="8"
                                            Padding="6,2,6,2"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="{Binding ProviderBalanceBadge}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProviderBalancePrimaryLabel}"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProviderBalancePrimaryValue}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextPrimary}" />
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProviderBalanceSecondaryLabel}"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProviderBalanceSecondaryValue}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextPrimary}" />
                                </Grid>

                                <TextBlock Text="{Binding ProviderBalanceStatus}"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Margin="0,0,0,8" />

                                <ui:Button Content="Refresh"
                                           Command="{Binding RefreshProviderBalanceCommand}"
                                           Style="{StaticResource SecondaryButton}"
                                           HorizontalAlignment="Stretch"
                                           Padding="10,4,10,4" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Expander Header="Personal Dictionary" IsExpanded="False" Margin="0,14,0,0">
                        <Border Style="{StaticResource PageFeatureSurface}" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="PERSONAL DICTIONARY" Style="{StaticResource PageFeatureLabel}" />

                                <Border Style="{StaticResource PageFeatureSurface}">
                                    <StackPanel>
                                        <TextBlock Text="Global Terms" Style="{StaticResource FieldLabel}" />
                                        <TextBlock Text="One term per line (names, product terms, acronyms)." Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                        <ui:TextBox Text="{Binding GlobalDictionaryTermsText}"
                                                    Style="{StaticResource InputTextArea}"
                                                    Height="110"
                                                    Margin="0,0,0,8" />
                                        <StackPanel Orientation="Horizontal">
                                            <ui:Button Content="Import"
                                                       Command="{Binding ImportGlobalDictionaryCommand}"
                                                       Style="{StaticResource SecondaryButton}"
                                                       Margin="0,0,8,0" />
                                            <ui:Button Content="Export"
                                                       Command="{Binding ExportGlobalDictionaryCommand}"
                                                       Style="{StaticResource SecondaryButton}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PageFeatureSurface}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ActiveProfileName, StringFormat=Profile Terms ({0})}" Style="{StaticResource FieldLabel}" />
                                        <TextBlock Text="Terms here only apply when this profile is active." Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                        <ui:TextBox Text="{Binding ProfileDictionaryTermsText}"
                                                    Style="{StaticResource InputTextArea}"
                                                    Height="90" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PageFeatureSurface}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Suggested Terms (Confirm to learn)" Style="{StaticResource FieldLabel}" />
                                        <TextBlock Text="Speakly proposes uncommon/proper terms from recent transcripts. Confirm each term to add it."
                                                   Style="{StaticResource HintText}"
                                                   Margin="0,0,0,6" />
                                        <ListBox ItemsSource="{Binding DictionarySuggestions}"
                                                 SelectedItem="{Binding SelectedDictionarySuggestion}"
                                                 MinHeight="96"
                                                 MaxHeight="120"
                                                 Style="{StaticResource InputList}"
                                                 HorizontalContentAlignment="Stretch"
                                                 Margin="0,0,0,8" />
                                        <WrapPanel Orientation="Horizontal">
                                            <ui:Button Content="Add to Global"
                                                       Command="{Binding AddSuggestionToGlobalDictionaryCommand}"
                                                       CommandParameter="{Binding SelectedDictionarySuggestion}"
                                                       Style="{StaticResource SecondaryButton}"
                                                       Margin="0,0,8,0" />
                                            <ui:Button Content="Add to Profile"
                                                       Command="{Binding AddSuggestionToProfileDictionaryCommand}"
                                                       CommandParameter="{Binding SelectedDictionarySuggestion}"
                                                       Style="{StaticResource SecondaryButton}"
                                                       Margin="0,0,8,0" />
                                            <ui:Button Content="Dismiss"
                                                       Command="{Binding DismissDictionarySuggestionCommand}"
                                                       CommandParameter="{Binding SelectedDictionarySuggestion}"
                                                       Style="{StaticResource SecondaryButton}"
                                                       Margin="0,0,8,0" />
                                            <ui:Button Content="Clear All"
                                                       Command="{Binding ClearDictionarySuggestionsCommand}"
                                                       Style="{StaticResource DangerButton}"
                                                       Margin="0" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Header="Advanced Settings" IsExpanded="False" Margin="0,14,0,0">
                        <Border Style="{StaticResource PageFeatureSurface}" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="ADVANCED" Style="{StaticResource PageFeatureLabel}" />
                                <TextBlock Text="For power users. Defaults are safe for most setups."
                                           Style="{StaticResource HintText}"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="Deepgram API Base URL" Style="{StaticResource FieldLabel}" />
                                <ui:TextBox Text="{Binding DeepgramApiBaseUrl}"
                                            Style="{StaticResource InputDefault}"
                                            Margin="0,0,0,4"
                                            MaxWidth="520"
                                            HorizontalAlignment="Left" />
                                <TextBlock Text="Default: https://api.deepgram.com. For EU use https://api.eu.deepgram.com, or set your dedicated/self-hosted endpoint."
                                           Style="{StaticResource HintText}" />
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>


