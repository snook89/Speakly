<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Design tokens: dark + cyan accent -->
    <Color x:Key="ColorBgBase">#111214</Color>
    <Color x:Key="ColorBgSurface">#141618</Color>
    <Color x:Key="ColorBgCard">#1C1F22</Color>
    <Color x:Key="ColorBgCardHover">#21262B</Color>
    <Color x:Key="ColorBgInput">#12161E</Color>
    <Color x:Key="ColorBgSidebar">#1D263F</Color>

    <Color x:Key="ColorBorderSubtle">#232831</Color>
    <Color x:Key="ColorBorderDefault">#2A313C</Color>
    <Color x:Key="ColorBorderStrong">#384456</Color>

    <Color x:Key="ColorTextPrimary">#E7E9EC</Color>
    <Color x:Key="ColorTextSecondary">#A9B0B7</Color>
    <Color x:Key="ColorTextMuted">#8A93A3</Color>
    <Color x:Key="ColorTextDisabled">#5F6877</Color>

    <Color x:Key="ColorAccent">#06B6D4</Color>
    <Color x:Key="ColorAccentHover">#22D3EE</Color>
    <Color x:Key="ColorAccentPressed">#0E7490</Color>
    <Color x:Key="ColorAccentGlow">#3306B6D4</Color>
    <Color x:Key="ColorAccentSubtle">#1906B6D4</Color>

    <Color x:Key="ColorSuccess">#10B981</Color>
    <Color x:Key="ColorWarning">#F59E0B</Color>
    <Color x:Key="ColorDanger">#EF4444</Color>
    <Color x:Key="ColorDangerSubtle">#1AEF4444</Color>

    <SolidColorBrush x:Key="BrushBgBase" Color="{StaticResource ColorBgBase}" />
    <SolidColorBrush x:Key="BrushBgSurface" Color="{StaticResource ColorBgSurface}" />
    <SolidColorBrush x:Key="BrushBgCard" Color="{StaticResource ColorBgCard}" />
    <SolidColorBrush x:Key="BrushBgCardHover" Color="{StaticResource ColorBgCardHover}" />
    <SolidColorBrush x:Key="BrushBgInput" Color="{StaticResource ColorBgInput}" />
    <SolidColorBrush x:Key="BrushBgSidebar" Color="{StaticResource ColorBgSidebar}" />

    <!-- WPF UI NavigationView pane uses BaseAlt surface brush -->
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource ColorBgSidebar}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseAltBrush" Color="{StaticResource ColorBgSidebar}" />
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource ColorBgSidebar}" />
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource ColorBgSidebar}" />
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource ColorBgSidebar}" />

    <SolidColorBrush x:Key="BrushBorderSubtle" Color="{StaticResource ColorBorderSubtle}" />
    <SolidColorBrush x:Key="BrushBorderDefault" Color="{StaticResource ColorBorderDefault}" />
    <SolidColorBrush x:Key="BrushBorderStrong" Color="{StaticResource ColorBorderStrong}" />

    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="BrushTextDisabled" Color="{StaticResource ColorTextDisabled}" />

    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource ColorAccentHover}" />
    <SolidColorBrush x:Key="BrushAccentPressed" Color="{StaticResource ColorAccentPressed}" />
    <SolidColorBrush x:Key="BrushAccentGlow" Color="{StaticResource ColorAccentGlow}" />
    <SolidColorBrush x:Key="BrushAccentSubtle" Color="{StaticResource ColorAccentSubtle}" />

    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushDangerSubtle" Color="{StaticResource ColorDangerSubtle}" />

    <!-- Overlay skin fallback keys (overridden by Themes/OverlaySkins/*.xaml) -->
    <LinearGradientBrush x:Key="OverlaySkin.PillowIdleBrush" StartPoint="0.1,0.1" EndPoint="0.9,0.9">
        <GradientStop Color="#EA15181D" Offset="0" />
        <GradientStop Color="#EA111418" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlaySkin.PillowHoverBrush" StartPoint="0.1,0.1" EndPoint="0.9,0.9">
        <GradientStop Color="#EE1A1F26" Offset="0" />
        <GradientStop Color="#EE141920" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlaySkin.PillowRecordingBrush" StartPoint="0.1,0.1" EndPoint="0.9,0.9">
        <GradientStop Color="#EE0E2D34" Offset="0" />
        <GradientStop Color="#EE0A242B" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlaySkin.PillowProcessingBrush" StartPoint="0.1,0.1" EndPoint="0.9,0.9">
        <GradientStop Color="#EE1C252A" Offset="0" />
        <GradientStop Color="#EE171F24" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="OverlaySkin.PillowIdleBorderBrush" Color="#334153" />
    <SolidColorBrush x:Key="OverlaySkin.PillowRecordingBorderBrush" Color="#06B6D4" />
    <SolidColorBrush x:Key="OverlaySkin.PillowProcessingBorderBrush" Color="#2F95B6" />

    <SolidColorBrush x:Key="OverlaySkin.IconIdleBrush" Color="#35CBE4" />
    <SolidColorBrush x:Key="OverlaySkin.IconRecordingBrush" Color="#8FE8F5" />
    <SolidColorBrush x:Key="OverlaySkin.IconProcessingBrush" Color="#7ED3E8" />

    <SolidColorBrush x:Key="OverlaySkin.TimerBackgroundBrush" Color="#2606B6D4" />
    <SolidColorBrush x:Key="OverlaySkin.TimerForegroundBrush" Color="#8FE8F5" />

    <SolidColorBrush x:Key="OverlaySkin.LanguageBadgeBrush" Color="#2206B6D4" />
    <SolidColorBrush x:Key="OverlaySkin.LanguageBadgeBorderBrush" Color="#2A8CA0" />
    <SolidColorBrush x:Key="OverlaySkin.LanguageBadgeForegroundBrush" Color="#92EAF8" />

    <SolidColorBrush x:Key="OverlaySkin.CancelBrush" Color="#331E0D0D" />
    <SolidColorBrush x:Key="OverlaySkin.CancelBorderBrush" Color="#A53D3D" />
    <SolidColorBrush x:Key="OverlaySkin.CancelForegroundBrush" Color="#FF8C8C" />

    <SolidColorBrush x:Key="OverlaySkin.ToastBrush" Color="#1B2530" />
    <SolidColorBrush x:Key="OverlaySkin.ToastBorderBrush" Color="#2D3F4E" />
    <SolidColorBrush x:Key="OverlaySkin.ToastForegroundBrush" Color="#D9E4EE" />

    <SolidColorBrush x:Key="OverlaySkin.MenuBrush" Color="#1A1F26" />
    <SolidColorBrush x:Key="OverlaySkin.MenuBorderBrush" Color="#2B3340" />
    <SolidColorBrush x:Key="OverlaySkin.MenuItemHoverBrush" Color="#1506B6D4" />
    <SolidColorBrush x:Key="OverlaySkin.MenuForegroundBrush" Color="#E7EDF4" />

    <SolidColorBrush x:Key="OverlaySkin.StatusForegroundBrush" Color="#E7EDF4" />
    <SolidColorBrush x:Key="OverlaySkin.SubtleTextBrush" Color="#A8B6C6" />
    <SolidColorBrush x:Key="OverlaySkin.AccentBrush" Color="#06B6D4" />
    <Color x:Key="OverlaySkin.ShadowColor">#AA000000</Color>

    <!-- Compatibility keys used by existing code-behind -->
    <SolidColorBrush x:Key="AppWarningPanelBrush" Color="#33F59E0B" />
    <SolidColorBrush x:Key="AppWarningBorderBrush" Color="#88F59E0B" />
    <SolidColorBrush x:Key="AppCaptureBgBrush" Color="#8B2A1B1B" />

    <SolidColorBrush x:Key="OverlayContainerBrush" Color="#E6111214" />
    <SolidColorBrush x:Key="OverlayPrimaryTextBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="OverlayLanguageBadgeBrush" Color="{StaticResource ColorAccentSubtle}" />
    <SolidColorBrush x:Key="OverlayLanguageTextBrush" Color="{StaticResource ColorAccentHover}" />
</ResourceDictionary>
