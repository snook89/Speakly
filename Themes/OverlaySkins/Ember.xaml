<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="OverlaySkin.PillowIdleBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFE8D0" Offset="0"/>
        <GradientStop Color="#FFD0A8" Offset="0.45"/>
        <GradientStop Color="#FFB880" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowHoverBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFECD8" Offset="0"/>
        <GradientStop Color="#FFD8B0" Offset="0.45"/>
        <GradientStop Color="#FFC088" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowRecordingBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FF9060" Offset="0"/>
        <GradientStop Color="#F07040" Offset="0.45"/>
        <GradientStop Color="#D05020" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowProcessingBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFC080" Offset="0"/>
        <GradientStop Color="#F0A060" Offset="0.45"/>
        <GradientStop Color="#E08040" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#88FFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="OverlaySkin.PillowIdleBorderBrush" Color="#F0C090"/>
    <SolidColorBrush x:Key="OverlaySkin.PillowRecordingBorderBrush" Color="#E06040"/>
    <SolidColorBrush x:Key="OverlaySkin.PillowProcessingBorderBrush" Color="#E0A060"/>

    <SolidColorBrush x:Key="OverlaySkin.IconIdleBrush" Color="#D05020"/>
    <SolidColorBrush x:Key="OverlaySkin.IconRecordingBrush" Color="#C04010"/>
    <SolidColorBrush x:Key="OverlaySkin.IconProcessingBrush" Color="#D05020"/>

    <SolidColorBrush x:Key="OverlaySkin.TimerBackgroundBrush" Color="#1FD05020"/>
    <SolidColorBrush x:Key="OverlaySkin.TimerForegroundBrush" Color="#C04010"/>

    <LinearGradientBrush x:Key="OverlaySkin.LanguageBadgeBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFE8D0" Offset="0"/>
        <GradientStop Color="#FFD8B8" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.LanguageBadgeBorderBrush" Color="#F0C090"/>
    <SolidColorBrush x:Key="OverlaySkin.LanguageBadgeForegroundBrush" Color="#B04020"/>

    <LinearGradientBrush x:Key="OverlaySkin.CancelBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFE4E4" Offset="0"/>
        <GradientStop Color="#FFD0D0" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.CancelBorderBrush" Color="#F8B8B8"/>
    <SolidColorBrush x:Key="OverlaySkin.CancelForegroundBrush" Color="#C02828"/>

    <LinearGradientBrush x:Key="OverlaySkin.ToastBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#E0F8EC" Offset="0"/>
        <GradientStop Color="#CCF0E0" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.ToastBorderBrush" Color="#A0D8B0"/>
    <SolidColorBrush x:Key="OverlaySkin.ToastForegroundBrush" Color="#1A6838"/>

    <LinearGradientBrush x:Key="OverlaySkin.MenuBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF8F0" Offset="0"/>
        <GradientStop Color="#FFF0E4" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.MenuBorderBrush" Color="#F8D8B0"/>
    <SolidColorBrush x:Key="OverlaySkin.MenuItemHoverBrush" Color="#0FD05020"/>
    <SolidColorBrush x:Key="OverlaySkin.MenuForegroundBrush" Color="#601800"/>

    <SolidColorBrush x:Key="OverlaySkin.StatusForegroundBrush" Color="#601800"/>
    <SolidColorBrush x:Key="OverlaySkin.SubtleTextBrush" Color="#F07840"/>
    <SolidColorBrush x:Key="OverlaySkin.AccentBrush" Color="#D05020"/>
    <Color x:Key="OverlaySkin.ShadowColor">#C09060</Color>

</ResourceDictionary>
