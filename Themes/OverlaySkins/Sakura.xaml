<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="OverlaySkin.PillowIdleBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFE4EF" Offset="0"/>
        <GradientStop Color="#FFCCE0" Offset="0.45"/>
        <GradientStop Color="#F8B0CC" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowHoverBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFECF4" Offset="0"/>
        <GradientStop Color="#FFD4E6" Offset="0.45"/>
        <GradientStop Color="#F8BCD0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowRecordingBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#F8B8D0" Offset="0"/>
        <GradientStop Color="#F090B0" Offset="0.45"/>
        <GradientStop Color="#E06888" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowProcessingBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#F8D0E8" Offset="0"/>
        <GradientStop Color="#F0B8D8" Offset="0.45"/>
        <GradientStop Color="#E898C0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlaySkin.PillowSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#88FFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="OverlaySkin.PillowIdleBorderBrush" Color="#F0C0D8"/>
    <SolidColorBrush x:Key="OverlaySkin.PillowRecordingBorderBrush" Color="#E08098"/>
    <SolidColorBrush x:Key="OverlaySkin.PillowProcessingBorderBrush" Color="#E0A8C8"/>

    <SolidColorBrush x:Key="OverlaySkin.IconIdleBrush" Color="#D04880"/>
    <SolidColorBrush x:Key="OverlaySkin.IconRecordingBrush" Color="#C03870"/>
    <SolidColorBrush x:Key="OverlaySkin.IconProcessingBrush" Color="#D04880"/>

    <SolidColorBrush x:Key="OverlaySkin.TimerBackgroundBrush" Color="#1FD04880"/>
    <SolidColorBrush x:Key="OverlaySkin.TimerForegroundBrush" Color="#C03870"/>

    <LinearGradientBrush x:Key="OverlaySkin.LanguageBadgeBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFE4EF" Offset="0"/>
        <GradientStop Color="#FFD0E4" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.LanguageBadgeBorderBrush" Color="#F0B8D0"/>
    <SolidColorBrush x:Key="OverlaySkin.LanguageBadgeForegroundBrush" Color="#C04878"/>

    <LinearGradientBrush x:Key="OverlaySkin.CancelBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#FFE4E4" Offset="0"/>
        <GradientStop Color="#FFD0D0" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.CancelBorderBrush" Color="#F8B8B8"/>
    <SolidColorBrush x:Key="OverlaySkin.CancelForegroundBrush" Color="#C02828"/>

    <LinearGradientBrush x:Key="OverlaySkin.ToastBrush" StartPoint="0.15,0.15" EndPoint="0.85,0.85">
        <GradientStop Color="#E8FFF0" Offset="0"/>
        <GradientStop Color="#D8F8E4" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.ToastBorderBrush" Color="#A0D8B0"/>
    <SolidColorBrush x:Key="OverlaySkin.ToastForegroundBrush" Color="#1A6838"/>

    <LinearGradientBrush x:Key="OverlaySkin.MenuBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF5F8" Offset="0"/>
        <GradientStop Color="#FFECF4" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlaySkin.MenuBorderBrush" Color="#F8D0E4"/>
    <SolidColorBrush x:Key="OverlaySkin.MenuItemHoverBrush" Color="#0FD04880"/>
    <SolidColorBrush x:Key="OverlaySkin.MenuForegroundBrush" Color="#780830"/>

    <SolidColorBrush x:Key="OverlaySkin.StatusForegroundBrush" Color="#780830"/>
    <SolidColorBrush x:Key="OverlaySkin.SubtleTextBrush" Color="#E878A8"/>
    <SolidColorBrush x:Key="OverlaySkin.AccentBrush" Color="#D04880"/>
    <Color x:Key="OverlaySkin.ShadowColor">#B08090</Color>

</ResourceDictionary>
